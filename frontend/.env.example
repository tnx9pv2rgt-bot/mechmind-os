# MechMind OS - Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL (with /v1 prefix)
NEXT_PUBLIC_API_URL=https://mechmind-backend.onrender.com/v1

# Frontend URL
NEXT_PUBLIC_APP_URL=https://mechmind-os.vercel.app

# WebAuthn / Passkeys
NEXT_PUBLIC_RP_ID=mechmind-os.vercel.app
NEXT_PUBLIC_RP_NAME=MechMind OS
NEXT_PUBLIC_ORIGIN=https://mechmind-os.vercel.app
