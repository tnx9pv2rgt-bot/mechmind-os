# ============================================
# MechMind OS - Environment Variables
# ============================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mechmind?schema=public"

# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (Create these in your Stripe Dashboard)
# Piccole Plan: €100/mese
STRIPE_PRICE_PICCOLE="price_..."
NEXT_PUBLIC_STRIPE_PRICE_PICCOLE="price_..."

# Medie Plan: €390.90/mese  
STRIPE_PRICE_MEDIE="price_..."
NEXT_PUBLIC_STRIPE_PRICE_MEDIE="price_..."

# Enterprise Plan (custom pricing)
STRIPE_PRICE_ENTERPRISE="price_..."
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE="price_..."

# AI Add-on: €200/mese
STRIPE_PRICE_AI_ADDON="price_..."
NEXT_PUBLIC_STRIPE_PRICE_AI_ADDON="price_..."

# Stripe Customer Portal Configuration (optional)
# Create at: https://dashboard.stripe.com/settings/billing/portal
STRIPE_PORTAL_CONFIGURATION_ID="bpc_..."

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Stripe Tax (automatic tax calculation)
# STRIPE_TAX_ENABLED="true"
