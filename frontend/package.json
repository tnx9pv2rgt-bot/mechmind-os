{
  "name": "mechmind-os-frontend",
  "version": "10.0.0",
  "description": "MechMind OS v10 - Enterprise Automotive Management Platform",
  "private": true,
  "scripts": {
    "postinstall": "echo 'No prisma generate needed - frontend uses backend API only'",
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build && node scripts/analyze-bundle.js",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:codegen": "playwright codegen",
    "test:e2e:report": "playwright show-report",
    "test:e2e:trace": "playwright test --trace on",
    "analyze": "node scripts/analyze-bundle.js",
    "lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "perf:audit": "npm run build && npm run analyze"
  },
