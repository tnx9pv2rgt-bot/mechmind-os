{
  "name": "MechMind OS - Full Stack",
  "dockerComposeFile": "docker-compose.codespaces.yml",
  "service": "backend",
  "workspaceFolder": "/workspaces/mechmind-os",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [3000, 3001, 8080, 8081, 5432, 6379],
  "portsAttributes": {
    "3000": {
      "label": "Backend API",
      "visibility": "public"
    },
    "3001": {
      "label": "Frontend",
      "visibility": "public"
    },
    "8080": {
      "label": "Adminer DB",
      "visibility": "public"
    },
    "8081": {
      "label": "Redis UI",
      "visibility": "public"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "bash .devcontainer/start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "remoteUser": "root"
}
