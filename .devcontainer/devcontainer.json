{
  "name": "MechMind OS",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [3000, 3001, 8080, 8081, 5432, 6379],
  "portsAttributes": {
    "3000": { "label": "Backend", "visibility": "public" },
    "3001": { "label": "Frontend", "visibility": "public" },
    "8080": { "label": "Adminer", "visibility": "public" },
    "8081": { "label": "Redis UI", "visibility": "public" }
  },
  "postCreateCommand": "docker-compose -f .devcontainer/docker-compose.codespaces.yml up -d",
  "remoteUser": "root"
}
