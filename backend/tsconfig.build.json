{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "sourceMap": false,
    "declaration": true,
    "removeComments": true,
    "outDir": "./dist"
  },
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*.spec.ts",
