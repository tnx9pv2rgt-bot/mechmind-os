# =============================================================================
# MechMind OS - Backend Environment Variables
# =============================================================================
# Copy this file to backend/.env and fill in the values
# cp env.example backend/.env

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
API_VERSION=v1

# -----------------------------------------------------------------------------
# Database (PostgreSQL 15)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/mechmind?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mechmind
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
DATABASE_CONNECTION_LIMIT=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Upstash Redis (production)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12
CSRF_SECRET=your-csrf-secret-min-16-chars
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3001

# -----------------------------------------------------------------------------
# Encryption (PII - AES-256-CBC)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# -----------------------------------------------------------------------------
# Frontend URL
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Email - Resend (primary)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=MechMind OS

# Email - SendGrid (legacy, optional)
# SENDGRID_API_KEY=SG.your-sendgrid-key
# EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# SMS - Twilio
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_STATUS_CALLBACK_URL=https://yourdomain.com/webhooks/twilio/status
# ENABLE_SMS_NOTIFICATIONS=false

# -----------------------------------------------------------------------------
# Voice - Vapi.ai
# -----------------------------------------------------------------------------
# VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# -----------------------------------------------------------------------------
# Stripe (Subscription & Billing)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_SMALL=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_MEDIUM=price_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_AI_ADDON=price_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# AWS (S3, SQS)
# -----------------------------------------------------------------------------
# AWS_REGION=eu-central-1
# AWS_S3_BUCKET=mechmind-uploads

# -----------------------------------------------------------------------------
# WebAuthn (Passkeys)
# -----------------------------------------------------------------------------
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_NAME=MechMind OS
# WEBAUTHN_ORIGIN=http://localhost:3001

# -----------------------------------------------------------------------------
# Metabase (Analytics Embedding)
# -----------------------------------------------------------------------------
# METABASE_URL=http://localhost:3003
# METABASE_SECRET_KEY=your-metabase-secret
# METABASE_EMBEDDING_ENABLED=false

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
# GOOGLE_PLACES_API_KEY=your-google-places-key
# ZEROBOUNCE_API_KEY=your-zerobounce-key

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log
