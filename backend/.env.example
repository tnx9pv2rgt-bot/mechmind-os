# ==========================================
# DATABASE
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/mechmind

# ==========================================
# REDIS
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_THROTTLE_DB=1

# ==========================================
# JWT
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# ==========================================
# STRIPE - SUBSCRIPTION BILLING
# ==========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each plan
STRIPE_PRICE_SMALL=price_small_plan_id
STRIPE_PRICE_MEDIUM=price_medium_plan_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_plan_id
STRIPE_PRICE_AI_ADDON=price_ai_addon_id

# ==========================================
# EXTERNAL SERVICES
# ==========================================
VAPI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==========================================
# AWS S3
# ==========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=

# ==========================================
# NOTIFICATIONS
# ==========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_AI_INSPECTIONS=true
ENABLE_VOICE_ASSISTANT=true
ENABLE_BLOCKCHAIN_VERIFICATION=false

# ==========================================
# PRICING DEFAULTS
# ==========================================
DEFAULT_TRIAL_DAYS=14
DEFAULT_CURRENCY=EUR
