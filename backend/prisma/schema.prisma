// MechMind OS v10 - Prisma Schema with Multi-Tenancy & RLS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// TENANT MODELS
// ==========================================

model Tenant {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  settings   Json     @default("{}")
  isActive   Boolean  @default(true) @map("is_active")
  apiKeyHash String?  @map("api_key_hash")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  users        User[]
  customers    Customer[]
  bookings     Booking[]
  bookingSlots BookingSlot[]
  services     Service[]

  // DVI
  inspections         Inspection[]
  inspectionTemplates InspectionTemplate[]
  aiDecisionOverrideAuditLogs AIDecisionOverrideAuditLog[]
  aiVoiceInteractionLogs AIVoiceInteractionLog[]

  // OBD
  obdDevices  ObdDevice[]
  obdReadings ObdReading[]

  // Parts
  parts              Part[]
  suppliers          Supplier[]
  inventoryItems     InventoryItem[]
  inventoryMovements InventoryMovement[]
  purchaseOrders     PurchaseOrder[]

  // Subscription & Pricing
  subscription Subscription?
  usageHistory UsageTracking[]
  locations    Location[]
  Notification Notification[]

  // GDPR
  customerEncrypted          CustomerEncrypted[]
  auditLogs                  AuditLog[]
  consentAuditLogs           ConsentAuditLog[]
  callRecordings             CallRecording[]
  dataSubjectRequests        DataSubjectRequest[]
  dataRetentionExecutionLogs DataRetentionExecutionLog[]

  // LPR (License Plate Recognition)
  lprCameras             LprCamera[]
  licensePlateDetections LicensePlateDetection[]

  // Shop Floor
  shopFloors      ShopFloor[]
  shopFloorEvents ShopFloorEvent[]
  workOrders      WorkOrder[]
  technicians     Technician[]

  // Vehicle Twin
  vehicleTwinConfigs     VehicleTwinConfig[]
  vehicleTwinComponents  VehicleTwinComponent[]
  componentHistories     ComponentHistory[]
  vehicleHealthHistories VehicleHealthHistory[]
  vehicleDamages         VehicleDamage[]

  // Fleet
  fleets        Fleet[]
  fleetVehicles FleetVehicle[]

  // Tires
  tireSets TireSet[]

  // Estimates
  estimates Estimate[]

  // Labor Guides
  laborGuides       LaborGuide[]
  laborGuideEntries LaborGuideEntry[]

  // Technician Time Logs
  technicianTimeLogs TechnicianTimeLog[]

  // Accounting
  accountingSyncs AccountingSync[]

  // Canned Jobs & Responses
  cannedJobs      CannedJob[]
  cannedResponses CannedResponse[]

  // SMS Threads
  smsThreads SmsThread[]

  // Vehicles
  vehicles Vehicle[]

  // Campaigns
  campaigns Campaign[]

  // RENTRI (Waste Management)
  wasteEntries      WasteEntry[]
  wasteFirs         WasteFir[]
  wasteTransporters WasteTransporter[]
  wasteDestinations WasteDestination[]

  // NIS2 Security Incidents
  securityIncidents SecurityIncident[]

  // AI Compliance (EU AI Act)
  aiDecisionLogs AiDecisionLog[]

  // Webhooks
  webhookSubscriptions WebhookSubscription[]

  @@map("tenants")
}

// ==========================================
// USER MODELS (Enhanced for NEXO SaaS Auth)
// ==========================================

model User {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email         String
  emailVerified DateTime? @map("email_verified")

  // Password (optional - for non-passkey users)
  passwordHash      String?   @map("password_hash")
  passwordChangedAt DateTime? @map("password_changed_at")

  // Profile
  name     String
  avatar   String?
  role     UserRole @default(MECHANIC) // ADMIN, MANAGER, MECHANIC, RECEPTIONIST, VIEWER
  isActive Boolean  @default(true) @map("is_active")

  // Passkeys (WebAuthn)
  passkeys Passkey[]

  // Recovery
  backupCodes           BackupCode[]
  recoveryEmail         String?      @map("recovery_email")
  recoveryPhone         String?      @map("recovery_phone") // encrypted via EncryptionService
  recoveryPhoneVerified Boolean      @default(false) @map("recovery_phone_verified")

  // MFA
  totpSecret     String?   @map("totp_secret") // encrypted
  totpEnabled    Boolean   @default(false) @map("totp_enabled")
  totpVerifiedAt DateTime? @map("totp_verified_at")
  smsOtpEnabled  Boolean   @default(false) @map("sms_otp_enabled")

  // Session/Device management
  sessions Session[]
  devices  Device[]

  // Security
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")

  // Preferences
  preferences Json? @default("{}")

  // Relations
  locationId String?   @map("location_id")
  location   Location? @relation(fields: [locationId], references: [id])

  // Audit
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  deletedAt  DateTime?    @map("deleted_at") // soft delete
  Inspection Inspection[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([email])
  @@index([createdAt])
  @@index([locationId])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  MECHANIC
  RECEPTIONIST
  VIEWER
}

// ==========================================
// CUSTOMER MODELS (with PII encryption)
// ==========================================

model Customer {
  id                 String    @id @default(uuid())
  encryptedPhone     String    @map("encrypted_phone")
  encryptedEmail     String?   @map("encrypted_email")
  encryptedFirstName String?   @map("encrypted_first_name")
  encryptedLastName  String?   @map("encrypted_last_name")
  phoneHash          String    @map("phone_hash") // For lookup without decryption
  emailHash          String?   @map("email_hash") // For login lookup without decryption
  passwordHash       String?   @map("password_hash") // Portal self-service login
  searchName         String?   @map("search_name") // Normalized lowercase name for server-side search
  gdprConsent        Boolean   @default(false) @map("gdpr_consent")
  gdprConsentAt      DateTime? @map("gdpr_consent_at")
  gdprPrivacyVersion String?   @default("2.0") @map("gdpr_privacy_version")
  gdprConsentMethod  String?   @default("form-checkbox") @map("gdpr_consent_method")
  marketingConsent   Boolean   @default(false) @map("marketing_consent")
  marketingConsentAt DateTime? @map("marketing_consent_at")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  // Dati fiscali (fatturazione elettronica italiana)
  customerType  CustomerType @default(PERSONA) @map("customer_type")
  codiceFiscale String?      @map("codice_fiscale")
  partitaIva    String?      @map("partita_iva")
  sdiCode       String?      @map("sdi_code")
  pecEmail      String?      @map("pec_email")

  // Indirizzo (obbligatorio per fatturazione)
  address    String? @map("address")
  city       String? @map("city")
  postalCode String? @map("postal_code")
  province   String? @map("province")
  country    String  @default("IT") @map("country")

  // Preferenze
  preferredChannel  ContactChannel? @map("preferred_channel")
  preferredLanguage String?         @default("it") @map("preferred_language")
  source            CustomerSource? @map("source")

  // Tenant relation
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Location relation (for multi-location support)
  locationId String?   @map("location_id")
  location   Location? @relation(fields: [locationId], references: [id])

  // Relations
  bookings                       Booking[]
  vehicles                       Vehicle[]
  invoices                       Invoice[]
  Inspection                     Inspection[]
  Notification                   Notification[]
  CustomerNotificationPreference CustomerNotificationPreference[]
  smsThreads                     SmsThread[]
  declinedServices               DeclinedService[]
  memberships                    CustomerMembership[]

  @@index([phoneHash])
  @@index([emailHash])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, searchName])
  @@index([locationId])
  @@map("customers")
}

// ==========================================
// CUSTOMER ENCRYPTED MODEL (GDPR Extended)
// ==========================================

model CustomerEncrypted {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Encrypted PII fields (stored as bytes for encrypted data)
  phoneEncrypted Bytes? @map("phone_encrypted")
  emailEncrypted Bytes? @map("email_encrypted")
  nameEncrypted  Bytes? @map("name_encrypted")
  phoneHash      String @map("phone_hash") // For lookup without decryption

  // Consent tracking
  gdprConsent          Boolean   @default(false) @map("gdpr_consent")
  gdprConsentDate      DateTime? @map("gdpr_consent_date")
  marketingConsent     Boolean   @default(false) @map("marketing_consent")
  marketingConsentDate DateTime? @map("marketing_consent_date")
  callRecordingConsent Boolean   @default(false) @map("call_recording_consent")

  // GDPR deletion/anonymization tracking
  isDeleted            Boolean   @default(false) @map("is_deleted")
  deletedAt            DateTime? @map("deleted_at")
  anonymizedAt         DateTime? @map("anonymized_at")
  dataSubjectRequestId String?   @map("data_subject_request_id")
  dataRetentionDays    Int?      @map("data_retention_days")

  // Relations
  vehicles         Vehicle[]
  bookings         Booking[]
  consentAuditLogs ConsentAuditLog[]

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  CallRecording CallRecording[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([phoneHash])
  @@index([anonymizedAt])
  @@index([isDeleted])
  @@map("customers_encrypted")
}

model Vehicle {
  id           String        @id @default(uuid())
  licensePlate String        @map("license_plate")
  make         String
  model        String
  year         Int?
  vin          String?
  notes        String?
  status       VehicleStatus @default(ACTIVE)
  mileage      Int?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Tenant relation
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Dati tecnici veicolo
  fuelType           FuelType?         @map("fuel_type")
  engineDisplacement Int?              @map("engine_displacement") // cc
  power              Int?              @map("power") // kW
  transmissionType   TransmissionType? @map("transmission_type")
  color              String?           @map("color")
  driveType          DriveType?        @map("drive_type")
  registrationDate   DateTime?         @map("registration_date")
  insuranceExpiry    DateTime?         @map("insurance_expiry")
  taxExpiry          DateTime?         @map("tax_expiry")

  // Customer relation (legacy)
  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Encrypted customer relation
  customerEncryptedId String?            @map("customer_encrypted_id")
  customerEncrypted   CustomerEncrypted? @relation(fields: [customerEncryptedId], references: [id], onDelete: Cascade)

  // Relations
  bookings    Booking[]
  inspections Inspection[]
  obdDevices  ObdDevice[]

  // Service tracking
  lastServiceDate  DateTime? @map("last_service_date")
  nextServiceDueKm Int?      @map("next_service_due_km")
  revisionExpiry   DateTime? @map("revision_expiry")

  // LPR relations
  entryExits      VehicleEntryExit[]
  parkingSessions ParkingSession[]

  // Shop Floor
  workOrders WorkOrder[]
  currentBay ServiceBay[]
  rfidTag    String?      @unique @map("rfid_tag")

  // Vehicle Twin
  twinConfig     VehicleTwinConfig?
  twinComponents VehicleTwinComponent[]
  healthHistory  VehicleHealthHistory[]
  damages        VehicleDamage[]

  // Soft delete (GDPR)
  deletedAt DateTime? @map("deleted_at")

  // Fleet
  fleetVehicles FleetVehicle[]

  // Documents
  documents VehicleDocument[]

  @@index([tenantId])
  @@map("vehicles")
}

model VehicleDocument {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  vehicleId  String    @map("vehicle_id")
  name       String
  docType    String    @map("doc_type") // LIBRETTO, ASSICURAZIONE, REVISIONE, BOLLO, ALTRO
  s3Key      String    @map("s3_key")
  mimeType   String    @map("mime_type")
  sizeBytes  Int       @map("size_bytes")
  uploadedBy String    @map("uploaded_by")
  expiryDate DateTime? @map("expiry_date")
  createdAt  DateTime  @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([vehicleId])
  @@map("vehicle_documents")
}

// ==========================================
// BOOKING MODELS
// ==========================================

model Booking {
  id              String        @id @default(uuid())
  status          BookingStatus @default(PENDING)
  scheduledDate   DateTime      @map("scheduled_date")
  durationMinutes Int           @default(60) @map("duration_minutes")
  notes           String?
  source          BookingSource @default(WEB)
  vapiCallId      String?       @map("vapi_call_id")
  technicianId    String?       @map("technician_id")
  liftPosition    String?       @map("lift_position")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  // Tenant relation
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  customerId          String?            @map("customer_id")
  customer            Customer?          @relation(fields: [customerId], references: [id])
  customerEncryptedId String?            @map("customer_encrypted_id")
  customerEncrypted   CustomerEncrypted? @relation(fields: [customerEncryptedId], references: [id])
  vehicleId           String?            @map("vehicle_id")
  vehicle             Vehicle?           @relation(fields: [vehicleId], references: [id])
  slotId              String             @unique @map("slot_id")
  slot                BookingSlot        @relation(fields: [slotId], references: [id])
  services            BookingService[]
  events              BookingEvent[]
  parts               BookingPart[]

  // Location relation (for multi-location support)
  locationId String?   @map("location_id")
  location   Location? @relation(fields: [locationId], references: [id])

  // Idempotency
  idempotencyKey String? @unique @map("idempotency_key")

  // Financial tracking for exports
  totalCostCents           BigInt?   @map("total_cost_cents")
  paymentStatus            String?   @map("payment_status")
  estimatedDurationMinutes Int?      @map("estimated_duration_minutes")
  Invoice                  Invoice[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([customerEncryptedId])
  @@index([scheduledDate])
  @@index([locationId])
  @@map("bookings")
}

model BookingSlot {
  id        String     @id @default(uuid())
  startTime DateTime   @map("start_time")
  endTime   DateTime   @map("end_time")
  status    SlotStatus @default(AVAILABLE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  // Tenant relation
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  booking Booking?

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, startTime, endTime])
  @@index([status])
  @@map("booking_slots")
}

model BookingEvent {
  id        String   @id @default(uuid())
  eventType String   @map("event_type")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  // Booking relation
  bookingId String  @map("booking_id")
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([eventType])
  @@index([createdAt])
  @@map("booking_events")
}

// ==========================================
// SERVICE MODELS
// ==========================================

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String?
  duration    Int      @default(60) // minutes
  price       Decimal  @db.Decimal(10, 2)
  laborRate   Decimal? @map("labor_rate") @db.Decimal(10, 2)
  isActive    Boolean  @default(true) @map("is_active")
  isCannedJob Boolean  @default(false) @map("is_canned_job")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Tenant relation
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  bookings          BookingService[]
  workOrderServices WorkOrderService[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("services")
}

model BookingService {
  id        String   @id @default(uuid())
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  bookingId String  @map("booking_id")
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
  @@map("booking_services")
}

// ==========================================
// INVOICE MODELS
// ==========================================

model Invoice {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  bookingId String?  @map("booking_id")
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  workOrderId String? @map("work_order_id")

  invoiceNumber String @map("invoice_number")

  status InvoiceStatus @default(DRAFT)

  /// @deprecated Use InvoiceItem relation instead
  // Legacy JSON items (kept for backward compatibility, prefer invoiceItems relation)
  items     Json?
  subtotal  Decimal @db.Decimal(10, 2)
  taxRate   Decimal @default(22) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount Decimal @map("tax_amount") @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  notes   String?
  dueDate DateTime? @map("due_date")
  sentAt  DateTime? @map("sent_at")
  paidAt  DateTime? @map("paid_at")
  pdfUrl  String?   @map("pdf_url")

  // Fatturazione elettronica italiana
  documentType    InvoiceDocumentType @default(FATTURA) @map("document_type")
  paymentMethod   PaymentMethod?      @map("payment_method")
  paymentTerms    PaymentTerms        @default(IMMEDIATO) @map("payment_terms")
  stampDuty       Boolean             @default(false) @map("stamp_duty")
  stampDutyAmount Decimal?            @map("stamp_duty_amount") @db.Decimal(10, 2)
  taxRegime       TaxRegime           @default(ORDINARIO) @map("tax_regime")

  // SDI (Sistema di Interscambio)
  sdiStatus         SdiStatus? @map("sdi_status")
  sdiTransmissionId String?    @map("sdi_transmission_id")
  xmlUrl            String?    @map("xml_url")

  // Nota di credito
  creditNoteOfId String?   @map("credit_note_of_id")
  creditNoteOf   Invoice?  @relation("CreditNote", fields: [creditNoteOfId], references: [id], onDelete: Restrict)
  creditNotes    Invoice[] @relation("CreditNote")

  // Relazione items normalizzata
  invoiceItems InvoiceItem[]

  // Text-to-Pay (Stripe Checkout)
  paymentLinkUrl String? @map("payment_link_url")
  paymentLinkId  String? @map("payment_link_id")

  // BNPL (Buy Now Pay Later — Scalapay)
  bnplProvider String? @map("bnpl_provider")
  bnplOrderId  String? @map("bnpl_order_id")
  bnplStatus   String? @map("bnpl_status")

  // Stripe payment idempotency
  stripeEventId String? @unique @map("stripe_event_id")

  // Art. 226 #8, DPR 633/1972 Art. 21 — Data operazione (se diversa da data emissione)
  operationDate DateTime? @map("operation_date")

  // Ritenuta d'acconto (Art. 25, DPR 600/1973)
  ritenutaType    String?  @map("ritenuta_type") // RT01=persone fisiche, RT02=persone giuridiche
  ritenutaRate    Decimal? @map("ritenuta_rate") @db.Decimal(5, 2) // Aliquota ritenuta (es. 20%)
  ritenutaAmount  Decimal? @map("ritenuta_amount") @db.Decimal(10, 2) // Importo ritenuta calcolato
  ritenutaCausale String?  @map("ritenuta_causale") // Causale pagamento (A-Z per CU)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([customerId])
  @@index([bookingId])
  @@map("invoices")
}

model InvoiceItem {
  id          String          @id @default(uuid())
  invoiceId   String          @map("invoice_id")
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  position    Int             @default(0)
  itemType    InvoiceItemType @default(SERVICE) @map("item_type")
  description String
  quantity    Decimal         @db.Decimal(10, 3)
  unitPrice   Decimal         @map("unit_price") @db.Decimal(10, 2)
  vatRate     Decimal         @map("vat_rate") @db.Decimal(5, 2)
  discount    Decimal         @default(0) @db.Decimal(5, 2)
  subtotal    Decimal         @db.Decimal(10, 2)
  vatAmount   Decimal         @map("vat_amount") @db.Decimal(10, 2)
  total       Decimal         @db.Decimal(10, 2)
  naturaIva   String?         @map("natura_iva") // Codice Natura IVA (N1-N7) per esenzioni/esclusioni
  partId      String?         @map("part_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([invoiceId])
  @@map("invoice_items")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceDocumentType {
  FATTURA
  NOTA_CREDITO
  PROFORMA
}

enum PaymentMethod {
  CONTANTI
  CARTA
  BONIFICO
  ASSEGNO
  BNPL
}

enum PaymentTerms {
  IMMEDIATO
  TRENTA_GIORNI
  SESSANTA_GIORNI
  FINE_MESE
}

enum TaxRegime {
  ORDINARIO
  SEMPLIFICATO
  FORFETTARIO
}

enum SdiStatus {
  SDI_PENDING
  SDI_SENT
  SDI_DELIVERED
  SDI_REJECTED
  SDI_NOT_DELIVERED
}

enum InvoiceItemType {
  LABOR
  PART
  EXTERNAL_SERVICE
  SERVICE
}

// ==========================================
// VOICE WEBHOOK EVENTS
// ==========================================

model VoiceWebhookEvent {
  id            String    @id @default(uuid())
  callId        String    @map("call_id")
  eventType     String    @map("event_type")
  tenantId      String    @map("tenant_id")
  customerPhone String?   @map("customer_phone")
  payload       Json
  processed     Boolean   @default(false)
  processedAt   DateTime? @map("processed_at")
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([callId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([eventType])
  @@index([processed])
  @@map("voice_webhook_events")
}

// ==========================================
// CALL RECORDINGS MODEL
// ==========================================

model CallRecording {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerId String?            @map("customer_id")
  customer   CustomerEncrypted? @relation(fields: [customerId], references: [id])

  // Recording metadata
  recordingSid    String?  @map("recording_sid") // Twilio recording SID
  recordingUrl    String?  @map("recording_url")
  durationSeconds Int      @map("duration_seconds")
  direction       String
  recordedAt      DateTime @default(now()) @map("recorded_at")

  // Retention and deletion
  retentionUntil DateTime? @map("retention_until")
  deletedAt      DateTime? @map("deleted_at")
  deletionReason String?   @map("deletion_reason")

  @@index([tenantId])
  @@index([customerId])
  @@index([deletedAt])
  @@index([retentionUntil])
  @@map("call_recordings")
}

