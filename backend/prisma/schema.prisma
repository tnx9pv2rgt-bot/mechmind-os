enum VehicleHistorySource {
  LOCAL
  MOTORNET
  CARFAX
  MANUAL
}

model VehicleHistoryRecord {
  id          String               @id @default(uuid())
  tenantId    String               @map("tenant_id")
  vehicleId   String               @map("vehicle_id")
  vin         String?
  source      VehicleHistorySource @default(LOCAL)
  eventType   String               @map("event_type") // SERVICE, REPAIR, INSPECTION, ACCIDENT, SALE
