  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([isActive])
  @@map("lpr_cameras")
}

enum EntryExitType {
