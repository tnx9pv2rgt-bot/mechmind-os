// ============================================
// ESTIMATES / QUOTES
// ============================================

model Estimate {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  estimateNumber String  @map("estimate_number") // EST-2026-001
  customerId     String  @map("customer_id")
  vehicleId      String? @map("vehicle_id")

  status EstimateStatus @default(DRAFT)

  // Financial (Decimal for monetary consistency)
  subtotalCents Decimal @map("subtotal_cents") @db.Decimal(10, 2)
  vatCents      Decimal @map("vat_cents") @db.Decimal(10, 2)
  totalCents    Decimal @map("total_cents") @db.Decimal(10, 2)
  discountCents Decimal @default(0) @map("discount_cents") @db.Decimal(10, 2)

  // Validity
  validUntil DateTime? @map("valid_until")
  sentAt     DateTime? @map("sent_at")
  acceptedAt DateTime? @map("accepted_at")
  rejectedAt DateTime? @map("rejected_at")

  // Conversion to booking
  bookingId String? @map("booking_id")

  notes     String?
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Good/Better/Best presentation
  presentationMode EstimatePresentationMode @default(SINGLE) @map("presentation_mode")

  // Digital approval
  approvalToken  String?   @map("approval_token")
  approvalSentAt DateTime? @map("approval_sent_at")
  approvalMethod String?   @map("approval_method") // SMS, WHATSAPP, EMAIL

  // Legal compliance — D.Lgs. 206/2005 Codice del Consumo
  customerSignature String?   @map("customer_signature") // nome scritto dal cliente come firma digitale
  customerSignedAt  DateTime? @map("customer_signed_at")
  termsAccepted     Boolean   @default(false) @map("terms_accepted")
  approvalIpAddress String?   @map("approval_ip_address")

  lines            EstimateLine[]
  declinedServices DeclinedService[]

  @@unique([tenantId, estimateNumber])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([customerId])
  @@index([status])
  @@map("estimates")
}

model EstimateLine {
  id         String   @id @default(uuid())
  estimateId String   @map("estimate_id")
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  type           EstimateLineType // LABOR, PART, OTHER
  description    String
  quantity       Int              @default(1)
  unitPriceCents Decimal          @map("unit_price_cents") @db.Decimal(10, 2)
  totalCents     Decimal          @map("total_cents") @db.Decimal(10, 2)
  vatRate        Decimal          @default(22.00) @map("vat_rate") @db.Decimal(5, 2)

  // Optional part reference
