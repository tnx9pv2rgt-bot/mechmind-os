  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([make])
  @@index([category])
  @@map("labor_guide_entries")
}

// ============================================
// ACCOUNTING SYNC
// ============================================

model AccountingSync {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Provider
  provider AccountingProvider
  externalId String? @map("external_id") // ID in external system

  // Entity being synced
  entityType String @map("entity_type") // INVOICE, CUSTOMER, PAYMENT
  entityId   String @map("entity_id")   // Internal ID

  // Sync status
  status    AccountingSyncStatus @default(PENDING)
  direction String @default("OUTBOUND") // OUTBOUND (us -> provider), INBOUND

  // Result
  syncedAt    DateTime? @map("synced_at")
  error       String?
  retryCount  Int       @default(0) @map("retry_count")
  lastRetryAt DateTime? @map("last_retry_at")

  // Payload
  payload  Json? // Data sent/received
  response Json? // Provider response

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([status])
  @@index([provider])
  @@map("accounting_syncs")
}

enum AccountingProvider {
  QUICKBOOKS
  XERO
  FATTUREINCLOUD
}

enum AccountingSyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
  SKIPPED
}

