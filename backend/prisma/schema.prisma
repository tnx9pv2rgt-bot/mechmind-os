// ============================================
// LPR (License Plate Recognition) MODELS
// ============================================

model LicensePlateDetection {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Detection details
  imageUrl      String   @map("image_url")
  detectedText  String   @map("detected_text")
  confidence    Float
  country       String?
  region        String?
  vehicleType   String?  @map("vehicle_type")
  boundingBox   Json?    @map("bounding_box")
  
  // Provider info
  provider      String
  rawResponse   Json?    @map("raw_response")
  
  // Camera reference
  cameraId      String?  @map("camera_id")
  camera        LprCamera? @relation(fields: [cameraId], references: [id])
  
  // Relations
  entryExits    VehicleEntryExit[]
  
  // Timestamps
  processedAt   DateTime @default(now()) @map("processed_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([detectedText])
  @@index([cameraId])
  @@index([processedAt])
