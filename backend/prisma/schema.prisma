enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  RESERVED
}

enum BookingSource {
  WEB
