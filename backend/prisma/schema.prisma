// ============================================
// TIRE MANAGEMENT
// ============================================

model TireSet {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicleId String? @map("vehicle_id")

  // Tire details
  brand   String
  model   String
  size    String  // e.g. "225/45 R17"
  season  TireSeason
  dot     String? // Manufacturing date code

  // Condition
  treadDepthMm Float? @map("tread_depth_mm") // mm remaining
  wearLevel    Float  @default(0) @map("wear_level") // 0-100%

  // Storage
  storageLocation String?  @map("storage_location") // e.g. "RACK-A3"
  isStored        Boolean  @default(false) @map("is_stored")
  storedAt        DateTime? @map("stored_at")

  // Mounting
  isMounted   Boolean   @default(false) @map("is_mounted")
  mountedAt   DateTime? @map("mounted_at")
  unmountedAt DateTime? @map("unmounted_at")

  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([vehicleId])
  @@index([season])
  @@index([isStored])
  @@map("tire_sets")
}

enum TireSeason {
  SUMMER
  WINTER
  ALL_SEASON
}

// ============================================
// ESTIMATES / QUOTES
// ============================================

model Estimate {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  estimateNumber String @unique @map("estimate_number") // EST-2026-001
  customerId     String @map("customer_id")
  vehicleId      String? @map("vehicle_id")

  status EstimateStatus @default(DRAFT)

  // Financial
  subtotalCents BigInt  @map("subtotal_cents")
  vatCents      BigInt  @map("vat_cents")
  totalCents    BigInt  @map("total_cents")
  discountCents BigInt  @default(0) @map("discount_cents")

  // Validity
  validUntil DateTime? @map("valid_until")
  sentAt     DateTime? @map("sent_at")
  acceptedAt DateTime? @map("accepted_at")
  rejectedAt DateTime? @map("rejected_at")

  // Conversion to booking
  bookingId String? @map("booking_id")

  notes     String?
  createdBy String  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lines EstimateLine[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([customerId])
  @@index([status])
  @@map("estimates")
}

model EstimateLine {
  id         String   @id @default(uuid())
  estimateId String   @map("estimate_id")
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  type        EstimateLineType // LABOR, PART, OTHER
  description String
  quantity    Int      @default(1)
  unitPriceCents BigInt @map("unit_price_cents")
  totalCents  BigInt   @map("total_cents")
  vatRate     Decimal  @default(22.00) @map("vat_rate") @db.Decimal(5, 2)

  // Optional part reference
  partId String? @map("part_id")

  position Int @default(0)

  @@index([estimateId])
  @@map("estimate_lines")
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum EstimateLineType {
  LABOR
  PART
  OTHER
}

