model MaintenanceScheduleTemplate {
  id                 String   @id @default(uuid())
  make               String
  model              String
  yearFrom           Int      @map("year_from")
  yearTo             Int      @map("year_to")
  serviceType        String   @map("service_type") // OIL_CHANGE, BRAKE_PADS, TIMING_BELT, etc.
  intervalKm         Int?     @map("interval_km")
  intervalMonths     Int?     @map("interval_months")
  description        String
  estimatedCostCents Decimal? @map("estimated_cost_cents") @db.Decimal(10, 2)

  @@index([make, model])
  @@map("maintenance_schedule_templates")
}

model PredictedMaintenance {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  vehicleId          String    @map("vehicle_id")
  customerId         String    @map("customer_id")
  serviceType        String    @map("service_type")
  predictedDate      DateTime  @map("predicted_date")
  predictedMileage   Int?      @map("predicted_mileage")
  confidence         Decimal   @default(0.70) @db.Decimal(3, 2)
  notificationSentAt DateTime? @map("notification_sent_at")
