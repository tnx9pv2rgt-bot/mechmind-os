// ============================================
// SHOP FLOOR MODELS
// ============================================

model ShopFloor {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name   String
  status String @default("ACTIVE")

  // Relations
  bays         ServiceBay[]
  parkingSpots ParkingSpot[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("shop_floors")
}

model ServiceBay {
  id          String    @id @default(uuid())
  shopFloorId String    @map("shop_floor_id")
  shopFloor   ShopFloor @relation(fields: [shopFloorId], references: [id], onDelete: Cascade)

  name   String
  type   String // LIFT, PIT, HOIST, DYNO, ALIGNMENT, DETAIL
  status ServiceBayStatus @default(AVAILABLE)

  // Location
  locationX Float @map("location_x")
  locationY Float @map("location_y")
  floor     Int   @default(1)

  // Capabilities
  capabilities     String[]
  maxVehicleWeight Float    @map("max_vehicle_weight")
  liftCapacity     Float?   @map("lift_capacity")

  // Current state
  currentVehicleId   String?    @map("current_vehicle_id")
  currentVehicle     Vehicle?   @relation(fields: [currentVehicleId], references: [id])
  currentWorkOrderId String?    @map("current_work_order_id")
  currentWorkOrder   WorkOrder? @relation(fields: [currentWorkOrderId], references: [id])
  checkInTime        DateTime?  @map("check_in_time")

  // Relations
  sensors        Sensor[]
  sensorReadings SensorReading[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([shopFloorId])
  @@index([status])
  @@map("service_bays")
}

model ParkingSpot {
  id          String    @id @default(uuid())
  shopFloorId String    @map("shop_floor_id")
  shopFloor   ShopFloor @relation(fields: [shopFloorId], references: [id], onDelete: Cascade)

  name   String
  type   String // WAITING, COMPLETED, CUSTOMER, STAFF
  status String @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED

  // Location
  locationX Float @map("location_x")
  locationY Float @map("location_y")

  vehicleId    String? @map("vehicle_id")
  licensePlate String? @map("license_plate")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([shopFloorId])
  @@index([status])
  @@map("parking_spots")
}

model Sensor {
  id    String     @id @default(uuid())
  bayId String     @map("bay_id")
  bay   ServiceBay @relation(fields: [bayId], references: [id], onDelete: Cascade)

  type     String // RFID, BLUETOOTH_BEACON, ULTRASONIC, PIR, CAMERA, PRESSURE, MAGNETIC
  name     String
  isActive Boolean @default(true) @map("is_active")

  lastReading  DateTime? @map("last_reading")
  batteryLevel Int?      @map("battery_level")
  config       Json?

  readings SensorReading[]

  @@index([bayId])
  @@index([type])
  @@map("sensors")
}

model SensorReading {
  id       String     @id @default(uuid())
  sensorId String     @map("sensor_id")
  sensor   Sensor     @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  bayId    String     @map("bay_id")
  bay      ServiceBay @relation(fields: [bayId], references: [id], onDelete: Cascade)

  type String // RFID, BLUETOOTH_BEACON, ULTRASONIC, PIR, CAMERA, PRESSURE, MAGNETIC
  data Json

  timestamp DateTime @default(now())

  @@index([sensorId])
  @@index([bayId])
  @@index([timestamp])
  @@map("sensor_readings")
}

model ShopFloorEvent {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type      String // VEHICLE_ENTRY, VEHICLE_EXIT, BAY_ASSIGNMENT, STATUS_CHANGE, TECHNICIAN_MOVE
  timestamp DateTime @default(now())

  bayId        String? @map("bay_id")
  vehicleId    String? @map("vehicle_id")
  technicianId String? @map("technician_id")
  workOrderId  String? @map("work_order_id")
  fromStatus   String? @map("from_status")
  toStatus     String? @map("to_status")
  message      String?

  metadata Json?

  @@index([tenantId])
  @@index([type])
  @@index([timestamp])
  @@map("shop_floor_events")
}

model WorkOrder {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  woNumber String          @map("wo_number")
  status   WorkOrderStatus @default(PENDING)

  // Relations
  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  customerId String @map("customer_id")

  technicianId String? @map("technician_id")

  bookingId String? @map("booking_id")

  assignedBayId String? @map("assigned_bay_id")

  // Diagnosis & customer input
  diagnosis       String? @db.Text
  customerRequest String? @map("customer_request") @db.Text

  // Cost tracking
  /// @deprecated Use WorkOrderService relation instead
  laborItems Json?    @map("labor_items")
  /// @deprecated Use WorkOrderPart relation instead
  partsUsed  Json?    @map("parts_used")
  laborHours Decimal? @map("labor_hours") @db.Decimal(5, 2)
  laborCost  Decimal? @map("labor_cost") @db.Decimal(10, 2)
  partsCost  Decimal? @map("parts_cost") @db.Decimal(10, 2)
  totalCost  Decimal? @map("total_cost") @db.Decimal(10, 2)

  // Vehicle state
  mileageIn  Int? @map("mileage_in")
  mileageOut Int? @map("mileage_out")

  // Media
  photos            Json?   @map("photos")
  customerSignature String? @map("customer_signature") @db.Text

  // Timestamps
  actualStartTime      DateTime? @map("actual_start_time")
  estimatedCompletion  DateTime? @map("estimated_completion")
  actualCompletionTime DateTime? @map("actual_completion_time")

  invoiceId  String? @map("invoice_id")
  estimateId String? @map("estimate_id")

  // Check-in / Check-out data
  fuelLevelIn  FuelLevel? @map("fuel_level_in")
  fuelLevelOut FuelLevel? @map("fuel_level_out")
  checkInData  Json?      @map("check_in_data")
  checkOutData Json?      @map("check_out_data")

  technicians WorkOrderTechnician[]
  services    WorkOrderService[]
  assignedBay ServiceBay[]
  parts       WorkOrderPart[]
  timeLogs    TechnicianTimeLog[]

  reviewRequestSentAt DateTime? @map("review_request_sent_at")

  // --- New DMS fields ---
  priority             String?   @default("NORMAL") @db.VarChar(20)
  woType               String?   @default("CUSTOMER_PAY") @map("wo_type") @db.VarChar(30)
  serviceAdvisorId     String?   @map("service_advisor_id")
  dropOffType          String?   @map("drop_off_type") @db.VarChar(30)
  courtesyCarRequested Boolean?  @default(false) @map("courtesy_car_requested")
  courtesyCarPlate     String?   @map("courtesy_car_plate") @db.VarChar(20)
  internalNotes        String?   @map("internal_notes") @db.Text
  customerVisibleNotes String?   @map("customer_visible_notes") @db.Text
  preExistingDamage    String?   @map("pre_existing_damage") @db.Text
  testDriveBefore      Boolean?  @default(false) @map("test_drive_before")
  testDriveAfter       Boolean?  @default(false) @map("test_drive_after")
  marketingSource      String?   @map("marketing_source") @db.VarChar(100)
  preAuthAmount        Decimal?  @map("pre_auth_amount") @db.Decimal(10, 2)
  taxExempt            Boolean?  @default(false) @map("tax_exempt")
  taxExemptCert        String?   @map("tax_exempt_cert") @db.VarChar(50)
  recallCheckDone      Boolean?  @default(false) @map("recall_check_done")
  parkingSpot          String?   @map("parking_spot") @db.VarChar(20)
  keyTag               String?   @map("key_tag") @db.VarChar(50)
  preferredContact     String?   @map("preferred_contact") @db.VarChar(20)
  estimatedPickup      DateTime? @map("estimated_pickup")

  // Optimistic locking
  version Int @default(0)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, woNumber])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([vehicleId])
  @@index([customerId])
  @@map("work_orders")
}

model TechnicianTimeLog {
