model VehicleTwinConfig {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicleId String  @unique @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Configuration
  isEnabled         Boolean @default(true) @map("is_enabled")
  syncInterval      Int     @default(300) @map("sync_interval") // seconds
  dataRetentionDays Int     @default(365) @map("data_retention_days")

  // Features
  trackLocation   Boolean @default(true) @map("track_location")
  trackHealth     Boolean @default(true) @map("track_health")
  trackComponents Boolean @default(true) @map("track_components")

  // Metadata
  lastSyncedAt DateTime? @map("last_synced_at")
  config       Json?     @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([vehicleId])
  @@map("vehicle_twin_configs")
}

model VehicleTwinComponent {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Component details
  name       String
  category   String // ENGINE, TRANSMISSION, BRAKES, SUSPENSION, ELECTRICAL, etc
  position   String? // Front, Rear, Left, Right, etc
  partNumber String? @map("part_number")

  // Lifecycle
  installedAt            DateTime @default(now()) @map("installed_at")
  expectedLifespanKm     Int?     @map("expected_lifespan_km")
  expectedLifespanMonths Int?     @map("expected_lifespan_months")

  // Current state
  status               String @default("ACTIVE") // ACTIVE, WARNING, CRITICAL, REPLACED
  condition            Float  @default(100.0) // 0-100 percentage
  wearLevel            Float  @default(0.0) // 0-100 percentage
  currentMileage       Int?   @map("current_mileage")
  estimatedRemainingKm Int?   @map("estimated_remaining_km")

  // Relations
  history ComponentHistory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([vehicleId])
  @@index([category])
  @@index([status])
  @@map("vehicle_twin_components")
}

model ComponentHistory {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  componentId String               @map("component_id")
  component   VehicleTwinComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  // Event details
  eventType String  @map("event_type") // INSTALLED, INSPECTED, REPLACED, REPAIRED, CONDITION_CHANGED
  mileage   Int?
  condition Float? // 0-100
  wearLevel Float?  @map("wear_level") // 0-100
  notes     String?

  // Relations
  workOrderId  String? @map("work_order_id")
  inspectionId String? @map("inspection_id")

  recordedAt DateTime @default(now()) @map("recorded_at")

  @@index([tenantId])
  @@index([componentId])
  @@index([eventType])
  @@index([recordedAt])
  @@map("component_histories")
}

model VehicleHealthHistory {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Health metrics
  overallScore      Int @map("overall_score") // 0-100
  engineScore       Int @map("engine_score") // 0-100
  transmissionScore Int @map("transmission_score") // 0-100
  brakesScore       Int @map("brakes_score") // 0-100
  suspensionScore   Int @map("suspension_score") // 0-100
  electricalScore   Int @map("electrical_score") // 0-100

  // OBD data
  hasErrorCodes Boolean  @default(false) @map("has_error_codes")
  errorCodes    String[] @default([]) @map("error_codes")

  // Metadata
  mileage    Int?
  recordedAt DateTime @default(now()) @map("recorded_at")
  source     String   @default("OBD") // OBD, INSPECTION, MANUAL

  @@index([tenantId])
  @@index([vehicleId])
  @@index([recordedAt])
  @@map("vehicle_health_histories")
}

model VehicleDamage {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  // Damage details
  type        String // SCRATCH, DENT, CRACK, TEAR, CORROSION, etc
  severity    String // MINOR, MODERATE, SEVERE
  category    String // EXTERIOR, INTERIOR, MECHANICAL, ELECTRICAL
  position    String? // Front bumper, Rear left door, etc
  description String?

  // Images
  images String[] // Array of image URLs

  // Status
  status String @default("ACTIVE") // ACTIVE, REPAIRED, DOCUMENTED

  // Relations
  inspectionId String? @map("inspection_id")

