  estimatedCompletion  DateTime? @map("estimated_completion")
  actualCompletionTime DateTime? @map("actual_completion_time")

  invoiceId  String? @map("invoice_id")
  estimateId String? @map("estimate_id")

  // Check-in / Check-out data
  fuelLevelIn  FuelLevel? @map("fuel_level_in")
  fuelLevelOut FuelLevel? @map("fuel_level_out")
  checkInData  Json?      @map("check_in_data")
  checkOutData Json?      @map("check_out_data")

  technicians WorkOrderTechnician[]
  services    WorkOrderService[]
  assignedBay ServiceBay[]
  parts       WorkOrderPart[]
  timeLogs    TechnicianTimeLog[]

