  @@index([tenantId, vehicleId])
  @@index([vin])
  @@map("vehicle_history_records")
}

// ==========================================
// WEBHOOKS
// ==========================================

model WebhookSubscription {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String // HTTPS endpoint del cliente
  events    String[] // ['booking.created', 'invoice.paid', ...]
  secret    String // segreto HMAC per firma payload
  isActive  Boolean  @default(true) @map("is_active")
  failCount Int      @default(0) @map("fail_count") // per disabilitare dopo troppi fallimenti
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("webhook_subscriptions")
}

// ==========================================
// AI VOICE INTERACTION LOG (EU AI Act)
// ==========================================
// Compliance with EU AI Act Article 13 & 14
// - Transparency: AI disclosure at call start
// - Audit trail: GDPR Art.22 automated decision-making
// - Opt-out: Customer "talk to human" request tracking

model AIVoiceInteractionLog {
  id String @id @default(uuid())

  callId        String @map("call_id")
  tenantId      String @map("tenant_id")
  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerPhone String? @map("customer_phone")

  // Decision type: 'ai_generated', 'human_escalated', 'ai_offer_escalation'
  decisionType     String @map("decision_type")
  confidence       Float? // AI confidence score (0-1)
  humanOverride    Boolean @map("human_override") // True if customer requested human
  escalationReason String? @map("escalation_reason") // Why escalation happened

  // Transcript markers for attribution (e.g., "[AI] response" vs "[Human] escalated")
  transcriptMarkers Json? @map("transcript_markers")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([callId])
  @@index([tenantId, createdAt])
  @@index([customerPhone])
  @@index([decisionType])
  @@index([humanOverride])
  @@map("ai_voice_interaction_logs")
}
