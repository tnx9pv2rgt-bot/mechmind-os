  CALL_RECORDING
  DATA_SHARING
  THIRD_PARTY
  ANALYTICS
}

// ============================================
// DATA SUBJECT REQUEST MODEL (GDPR Art. 12-22)
// ============================================

model DataSubjectRequest {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Ticket info
  ticketNumber String @unique @map("ticket_number")
  requestType  String @map("request_type") // ACCESS, DELETION, RECTIFICATION, PORTABILITY, RESTRICTION, OBJECTION
  status       String @default("RECEIVED") // RECEIVED, VERIFICATION_PENDING, VERIFIED, IN_PROGRESS, COMPLETED, REJECTED, CANCELLED

  // Requester info
  requesterEmail String? @map("requester_email")
  requesterPhone String? @map("requester_phone")
  customerId     String? @map("customer_id")

  // SLA tracking
  receivedAt  DateTime  @default(now()) @map("received_at")
  deadlineAt  DateTime  @map("deadline_at")
  verifiedAt  DateTime? @map("verified_at")
  completedAt DateTime? @map("completed_at")
  slaMet      Boolean?  @map("sla_met")

  // Source and priority
  source   String @default("EMAIL") // EMAIL, WEB_FORM, PHONE, MAIL
  priority String @default("NORMAL") // LOW, NORMAL, HIGH, URGENT

  // Assignment
  assignedTo String? @map("assigned_to")

  // Identity verification
  identityVerified      Boolean  @default(false) @map("identity_verified")
  verificationMethod    String?  @map("verification_method")
  verificationDocuments String[] @default([]) @map("verification_documents")

  // Rejection tracking
  rejectionReason String? @map("rejection_reason")
  rejectionBasis  String? @map("rejection_basis")

  // Export format for access requests
  exportFormat String? @map("export_format") // JSON, CSV, PDF

  // Deletion snapshot
  deletionSnapshotCreated Boolean @default(false) @map("deletion_snapshot_created")
  deletionSnapshotUrl     String? @map("deletion_snapshot_url")

  // Notes
  notes String?

  // Metadata
  metadata Json? @default("{}")

  @@index([tenantId])
  @@index([ticketNumber])
  @@index([status])
  @@index([receivedAt])
  @@index([deadlineAt])
  @@index([customerId])
  @@map("data_subject_requests")
}

// ============================================
// DATA RETENTION EXECUTION LOG MODEL
