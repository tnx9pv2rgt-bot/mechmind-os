model SupplierApiConfig {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  supplierName String    @map("supplier_name") // AUTODOC, TECDOC, LOCAL
  apiEndpoint  String?   @map("api_endpoint")
