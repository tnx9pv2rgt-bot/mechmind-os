  FLAT_RATE
  MIXED
}

enum GoalType {
  EFFICIENCY
  REVENUE
  JOBS_PER_DAY
  HOURS_BILLED
}

enum GoalPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

model TechnicianGoal {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  technicianId String     @map("technician_id")
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  goalType     GoalType   @map("goal_type")
  targetValue  Decimal    @map("target_value") @db.Decimal(10, 2)
  currentValue Decimal    @default(0) @map("current_value") @db.Decimal(10, 2)
  period       GoalPeriod
  startDate    DateTime   @map("start_date")
  endDate      DateTime   @map("end_date")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([tenantId, technicianId])
  @@map("technician_goals")
}

model TechnicianPayConfig {
  id                     String     @id @default(uuid())
  tenantId               String     @map("tenant_id")
  technicianId           String     @map("technician_id")
  technician             Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  payType                PayType    @map("pay_type")
  hourlyRateCents        Decimal?   @map("hourly_rate_cents") @db.Decimal(10, 2)
  flatRatePerJobCents    Decimal?   @map("flat_rate_per_job_cents") @db.Decimal(10, 2)
  overtimeMultiplier     Decimal    @default(1.5) @map("overtime_multiplier") @db.Decimal(3, 2)
  overtimeThresholdHours Decimal    @default(40) @map("overtime_threshold_hours") @db.Decimal(5, 2)
  bonusRules             Json?      @map("bonus_rules")
  effectiveFrom          DateTime   @map("effective_from")
  effectiveTo            DateTime?  @map("effective_to")
  createdAt              DateTime   @default(now()) @map("created_at")

  @@index([tenantId, technicianId])
  @@map("technician_pay_configs")
}

model PayrollRecord {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  technicianId     String        @map("technician_id")
  technician       Technician    @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  period           String // "2026-03" format
  regularHours     Decimal       @map("regular_hours") @db.Decimal(6, 2)
  overtimeHours    Decimal       @default(0) @map("overtime_hours") @db.Decimal(6, 2)
  regularPayCents  Decimal       @map("regular_pay_cents") @db.Decimal(10, 2)
  overtimePayCents Decimal       @default(0) @map("overtime_pay_cents") @db.Decimal(10, 2)
  bonusPayCents    Decimal       @default(0) @map("bonus_pay_cents") @db.Decimal(10, 2)
  totalPayCents    Decimal       @map("total_pay_cents") @db.Decimal(10, 2)
  status           PayrollStatus @default(DRAFT)
  approvedBy       String?       @map("approved_by")
  approvedAt       DateTime?     @map("approved_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@unique([tenantId, technicianId, period])
  @@index([tenantId])
  @@index([tenantId, period])
  @@map("payroll_records")
}

// ============================================================================
// BENCHMARKING — Industry comparison metrics
// ============================================================================

model BenchmarkMetric {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  period      String // "2026-03"
  metricType  String   @map("metric_type") // ARO, CAR_COUNT, LABOR_RATE, PARTS_MARGIN, TECH_EFFICIENCY
  value       Decimal  @db.Decimal(10, 2)
  percentile  Int? // 0-100, shop's ranking
  industryAvg Decimal? @map("industry_avg") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([tenantId, period, metricType])
  @@index([tenantId])
  @@map("benchmark_metrics")
}

model IndustryBenchmark {
  id           String   @id @default(uuid())
  region       String // "IT", "EU", "US"
  shopSize     String   @map("shop_size") // SMALL, MEDIUM, LARGE
  period       String // "2026-03"
  metricType   String   @map("metric_type")
  avgValue     Decimal  @map("avg_value") @db.Decimal(10, 2)
  medianValue  Decimal  @map("median_value") @db.Decimal(10, 2)
  p25          Decimal  @db.Decimal(10, 2)
  p75          Decimal  @db.Decimal(10, 2)
  sampleSize   Int      @map("sample_size")
  calculatedAt DateTime @map("calculated_at")

  @@unique([region, shopSize, period, metricType])
  @@map("industry_benchmarks")
}

