  discoveredAt DateTime  @default(now()) @map("discovered_at")
  repairedAt   DateTime? @map("repaired_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([vehicleId])
  @@index([status])
