  name        String
  description String?
  source      String? // e.g. "MANUFACTURER", "CUSTOM", "AUTODATA"
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entries LaborGuideEntry[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@unique([tenantId, name])
  @@map("labor_guides")
}

model LaborGuideEntry {
  id      String     @id @default(uuid())
  guideId String     @map("guide_id")
  guide   LaborGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  tenantId String    @map("tenant_id")
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Vehicle matching
  make  String
  model String?
  yearFrom Int? @map("year_from")
  yearTo   Int? @map("year_to")

  // Operation
  operationCode String  @map("operation_code")
  operationName String  @map("operation_name")
