    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "csv-writer": "^1.6.0",
    "date-fns": "^3.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^6.2.1",
    "nest-winston": "^1.9.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prisma": "5.22.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.1",
    "resend": "^6.9.3",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "ts-node": "^10.9.2",
