{
  "name": "mechmind-os-backend",
  "version": "10.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build -p tsconfig.build.json",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lambda:build": "nest build --webpack --webpackPath webpack.config.js",
    "lambda:zip": "cd dist && zip -r ../lambda.zip . && cd ..",
    "lambda:package": "npm run lambda:build && npm run lambda:zip",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:unit": "jest --config jest.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:security": "jest --testPathPattern='security'",
    "test:security:owasp": "jest --testNamePattern='OWASP'",
    "test:security:gdpr": "jest --testNamePattern='GDPR'",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "test:db:setup": "ts-node scripts/setup-test-db.ts",
    "db:seed": "ts-node scripts/seed.ts",
    "db:seed:e2e": "ts-node scripts/seed-e2e.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:reset": "prisma migrate reset",
    "generate": "prisma generate",
    "postinstall": "prisma generate || true",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "^1.0.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/bullmq": "^10.1.0",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^2.0.3",
    "@nestjs/jwt": "^10.2.0",
