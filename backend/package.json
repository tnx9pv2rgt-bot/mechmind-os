    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "5.22.0",
    "@react-email/components": "^1.0.8",
    "@sendgrid/mail": "^8.1.3",
    "@simplewebauthn/server": "^13.2.3",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
