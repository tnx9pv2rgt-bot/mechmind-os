# ─── Nexo Gestionale — Environment Variables ──────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.
# Secrets marked [SECRET] must be generated randomly.
# Generate secrets: openssl rand -hex 64
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────────
# Direct connection (migrations, seed):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mechmind?schema=public
# Via PgBouncer (runtime — transaction mode):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mechmind?schema=public&connection_limit=20&pool_timeout=20
DATABASE_CONNECTION_LIMIT=20

# Postgres credentials (docker-compose):
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-strong-password-in-production
POSTGRES_DB=mechmind

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PUBSUB_DB=1
# REDIS_PASSWORD=                  # Required in production
# REDIS_TLS=true                   # Required in production

# ── Authentication ───────────────────────────────────────────────────────────
# [SECRET] Generate with: openssl rand -hex 64
JWT_SECRET=change-me-minimum-64-chars-random-value-do-not-use-in-production!!!!
JWT_REFRESH_SECRET=change-me-minimum-64-chars-random-refresh-secret-do-not-use!!
JWT_2FA_SECRET=change-me-minimum-64-chars-random-2fa-secret-do-not-use!!!!!!!!!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_EXPIRES_IN_SECONDS=900
# RS256 (optional — leave empty to use HS256 with JWT_SECRET):
# JWT_PRIVATE_KEY_PEM=
# JWT_AUTO_GENERATE_KEYS=false

# ── Encryption (PII — AES-256-CBC) ──────────────────────────────────────────
# [SECRET] Must be exactly 64 hex chars (32 bytes):
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# [SECRET] Must be exactly 32 hex chars (16 bytes):
ENCRYPTION_IV=0123456789abcdef0123456789abcdef

# ── Frontend / CORS ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3002
BACKEND_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin Setup ──────────────────────────────────────────────────────────────
# [SECRET] Used to protect POST /v1/admin/setup endpoint:
SETUP_SECRET=change-me-setup-secret
DEMO_PASSWORD=Demo2026!

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
# [SECRET]
SENDGRID_API_KEY=SG.change-me
EMAIL_FROM_ADDRESS=noreply@mechmind.it
EMAIL_FROM_NAME=MechMind OS
ENABLE_EMAIL_NOTIFICATIONS=true

# ── Email (Resend — alternative) ─────────────────────────────────────────────
# RESEND_API_KEY=re_change-me
# RESEND_WEBHOOK_SECRET=whsec_change-me

# ── Email (AWS SES — alternative) ────────────────────────────────────────────
# SES_FROM_EMAIL=noreply@mechmind.it
# SES_CONFIGURATION_SET=mechmind-transactional

# ── PEC SMTP (Posta Elettronica Certificata) ─────────────────────────────────
# PEC_SMTP_HOST=smtps.legalmail.it
# PEC_SMTP_PORT=465
# PEC_SMTP_USER=mechmind@legalmail.it
# PEC_SMTP_PASS=change-me

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# [SECRET]
# TWILIO_ACCOUNT_SID=ACchange-me
# TWILIO_AUTH_TOKEN=change-me
# TWILIO_PHONE_NUMBER=+39xxxxxxxxxx
# TWILIO_WHATSAPP_NUMBER=whatsapp:+39xxxxxxxxxx
# TWILIO_VERIFY_SERVICE_SID=VAchange-me
# TWILIO_STATUS_CALLBACK_URL=https://api.mechmind.it/v1/twilio/status
# TWILIO_WEBHOOK_URL=https://api.mechmind.it/v1/twilio/webhook
ENABLE_SMS_NOTIFICATIONS=false

# ── Stripe ───────────────────────────────────────────────────────────────────
# [SECRET]
# STRIPE_SECRET_KEY=sk_test_change-me
# STRIPE_WEBHOOK_SECRET=whsec_change-me
# STRIPE_PRICE_SMALL=price_change-me      # Starter €39/mese
# STRIPE_PRICE_MEDIUM=price_change-me     # Professional €89/mese
# STRIPE_PRICE_ENTERPRISE=price_change-me # Enterprise €249/mese
# STRIPE_PRICE_AI_ADDON=price_change-me   # AI Add-on
# STRIPE_PRICE_VOICE_ADDON=price_change-me # Voice Add-on

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# [SECRET]
# AI_PROVIDER=openai               # openai | anthropic
# AI_API_KEY=sk-change-me
# AI_MODEL=gpt-4o-mini
# ML_API_URL=https://api.mechmind.it/ml
# ML_API_KEY=change-me
# ML_API_TIMEOUT_MS=10000

# ── Voice AI (Vapi) ──────────────────────────────────────────────────────────
# [SECRET]
# VAPI_WEBHOOK_SECRET=change-me

# ── AWS / S3 ─────────────────────────────────────────────────────────────────
# [SECRET]
# AWS_REGION=eu-south-1
# AWS_ACCESS_KEY_ID=AKIA-change-me
# AWS_SECRET_ACCESS_KEY=change-me
# AWS_S3_BUCKET=mechmind-fatture-prod

# ── WebAuthn / Passkeys ──────────────────────────────────────────────────────
WEBAUTHN_RP_NAME=MechMind OS
WEBAUTHN_RP_ID=mechmind.it
WEBAUTHN_ORIGIN=https://mechmind.it

# ── SDI / FatturaPA v1.9.1 (obbligatorio dal 15/05/2026) ─────────────────────
ENABLE_SDI_SANDBOX=true
SDI_SANDBOX_BASE_URL=https://ivaservizi.agenziaentrate.gov.it/ser/
SDI_SANDBOX_USERNAME=change-me
SDI_SANDBOX_PASSWORD=change-me

# ── Google ───────────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=change-me.apps.googleusercontent.com
# GOOGLE_PLACES_API_KEY=AIza-change-me

# ── VIES (EU VAT validation) ─────────────────────────────────────────────────
VIES_API_URL=https://ec.europa.eu/taxation_customs/vies/checkVatService

# ── ZeroBounce (email validation) ────────────────────────────────────────────
# ZEROBOUNCE_API_KEY=change-me

# ── CRM Integrations (optional) ──────────────────────────────────────────────
# HUBSPOT_API_KEY=change-me
# PIPEDRIVE_API_TOKEN=change-me
# PIPEDRIVE_API_URL=https://api.pipedrive.com/v1
# SALESFORCE_ACCESS_TOKEN=change-me
# SALESFORCE_API_URL=https://myorg.salesforce.com

# ── Webhook Signing Secrets ──────────────────────────────────────────────────
# [SECRET]
# GDPR_WEBHOOK_SECRET=change-me
# SCALAPAY_WEBHOOK_SECRET=change-me
# SEGMENT_WEBHOOK_SECRET=change-me
# SLACK_BOT_TOKEN=xoxb-change-me
# SLACK_SIGNING_SECRET=change-me
# ZAPIER_WEBHOOK_SECRET=change-me

# ── Sentry ───────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://change-me@sentry.io/change-me

# ── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Metabase (Analytics Embedding) ───────────────────────────────────────────
METABASE_EMBEDDING_ENABLED=false
# METABASE_URL=https://analytics.mechmind.it
# METABASE_SECRET_KEY=change-me

# ── Unit Economics (Analytics) ───────────────────────────────────────────────
UNIT_ECONOMICS_ARPA=89
UNIT_ECONOMICS_COGS_PER_SHOP=15
UNIT_ECONOMICS_FIXED_COSTS=5000
UNIT_ECONOMICS_GROSS_MARGIN=0.83

# ── GDPR Retention Policies (days) ───────────────────────────────────────────
GDPR_AUDIT_LOG_DAYS=2555          # 7 years (Art. 226 VAT directive)
GDPR_BOOKING_RETENTION_DAYS=730   # 2 years
GDPR_CUSTOMER_RETENTION_DAYS=1825 # 5 years
GDPR_CONSENT_LOG_DAYS=2555        # 7 years
GDPR_OPTOUT_RETENTION_DAYS=3650   # 10 years (legal hold)
GDPR_RECORDING_RETENTION_DAYS=90  # 3 months
GDPR_WEBHOOK_EVENT_DAYS=90        # 3 months

# ── Ngrok (share local — docker compose --profile share) ─────────────────────
# NGROK_AUTHTOKEN=change-me
# NGROK_DOMAIN=mechmind.ngrok.app

# ── Load Testing ─────────────────────────────────────────────────────────────
LOAD_TEST=false
