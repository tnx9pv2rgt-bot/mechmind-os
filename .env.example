# ==========================================
# MechMind OS v10 - Docker Compose Environment
# ==========================================
# Copy this file to .env and configure for production

# ==========================================
# PostgreSQL Database
# ==========================================
POSTGRES_USER=mechmind
POSTGRES_PASSWORD=change-this-strong-password-in-production
POSTGRES_DB=mechmind_os

# ==========================================
# Application
# ==========================================
NODE_ENV=production
PORT=3000
API_VERSION=v1
APP_NAME=MechMind OS

# ==========================================
# JWT Authentication (min 32 characters)
# ==========================================
JWT_SECRET=change-this-to-a-very-long-random-secret-key-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# Encryption (32 chars for key, 16 for IV)
# ==========================================
ENCRYPTION_KEY=your-32-char-encryption-key!!
ENCRYPTION_IV=your-16-char-iv!!

# ==========================================
# Vapi Voice Integration
# ==========================================
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret
VAPI_API_KEY=your-vapi-api-key

# ==========================================
# SendGrid / Resend (Email)
# ==========================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
RESEND_API_KEY=re_your_resend_api_key
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret
EMAIL_FROM_ADDRESS=noreply@mechmind.io
EMAIL_FROM_NAME=MechMind

# ==========================================
# Twilio (SMS)
# ==========================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ==========================================
# Feature Flags
# ==========================================
ENABLE_VOICE_BOOKING=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true

# ==========================================
# Frontend URL (for CORS)
# ==========================================
FRONTEND_URL=https://app.mechmind.io
