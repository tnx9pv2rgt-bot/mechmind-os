# ============================================
# MechMind OS v10 - Voice AI Configuration
# ============================================

# Server Configuration
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ============================================
# Vapi.ai Configuration
# ============================================
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
VAPI_API_KEY=your_vapi_api_key_here

# ============================================
# Twilio Configuration
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_SMS_NUMBER=+39123456789

# ============================================
# Backend API Configuration
# ============================================
BACKEND_API_URL=https://api.mechmind-os.com
BACKEND_API_TOKEN=your_backend_api_token_here

# ============================================
# Fallback Numbers
# ============================================
FALLBACK_SHOP_NUMBER=+39987654321
EMERGENCY_NUMBER=+390987654321

# ============================================
# Webhook Base URL
# ============================================
WEBHOOK_BASE_URL=https://voice.mechmind-os.com

# ============================================
# Security
# ============================================
ALLOWED_ORIGINS=https://api.mechmind-os.com,https://dashboard.mechmind-os.com

# ============================================
# Feature Flags
# ============================================
ENABLE_SMS_CONFIRMATIONS=true
ENABLE_CALL_RECORDING=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_ESCALATION=true

# ============================================
# Performance
# ============================================
MAX_RESPONSE_TIME_MS=2500
FALLBACK_TIMEOUT_MS=5000
CACHE_TTL_MINUTES=5
