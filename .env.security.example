# NEXO Security Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# REDIS / UPSTASH CONFIGURATION
# ============================================
UPSTASH_REDIS_REST_URL=https://your-project.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ============================================
# JWT CONFIGURATION
# ============================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# ENCRYPTION
# ============================================
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# PASSKEY / WEBAUTHN
# ============================================
WEBAUTHN_RP_NAME=NEXO
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ============================================
# SECURITY SETTINGS
# ============================================
# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate limiting (true/false)
ENABLE_RATE_LIMITING=true

# Audit logging (true/false)
ENABLE_AUDIT_LOGGING=true

# Require email verification (true/false)
REQUIRE_EMAIL_VERIFICATION=true

# ============================================
# MONITORING & ALERTING
# ============================================
# Slack webhook for security alerts
SLACK_SECURITY_WEBHOOK_URL=

# Email for security notifications
SECURITY_ALERT_EMAIL=security@yourdomain.com
