# ============================================================================
# Metabase Environment Configuration
# MechMind OS - Business Intelligence
# ============================================================================
# Copia questo file in .env e configura i valori reali
# NON committare il file .env con credenziali reali!
# ============================================================================

# ---------------------------------------------------------------------------
# Metabase Application Settings
# ---------------------------------------------------------------------------

# URL pubblico di Metabase (usato per generare link embed)
METABASE_URL=http://localhost:3001

# Secret key per JWT signing (deve essere esattamente 32 caratteri)
# Genera con: openssl rand -base64 32 | cut -c1-32
METABASE_SECRET_KEY=change_this_to_a_32_character_secret_key

# Abilita/disabilita l'embedding
METABASE_EMBEDDING_ENABLED=true

# Token premium Metabase (opzionale, per feature aggiuntive)
METABASE_PREMIUM_TOKEN=

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------

# Password per il database interno di Metabase (PostgreSQL)
METABASE_DB_PASSWORD=metabase_secure_password

# ---------------------------------------------------------------------------
# Email Configuration (opzionale, per alert e report)
# ---------------------------------------------------------------------------

# Indirizzo email del mittente
EMAIL_FROM=noreply@mechmind.local

# SMTP Settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURITY=starttls

# ---------------------------------------------------------------------------
# Frontend Configuration
# ---------------------------------------------------------------------------

# URL del frontend per CORS embedding
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Main Application Database (per analytics refresh)
# ---------------------------------------------------------------------------

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mechmind
