// Multi-factor Authentication with TOTP
// ============================================================================

// Add these models to your main schema.prisma file

model UserMFA {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @unique @map("user_id") @db.Uuid
  secret            String    // Encrypted TOTP secret (base32)
  enabled           Boolean   @default(false)
  verifiedAt        DateTime? @map("verified_at") @db.Timestamptz(6)
  backupCodes       String[]  @default([]) @map("backup_codes") // Hashed backup codes
  verifyAttempts    Int       @default(0) @map("verify_attempts")
  lastVerifyAttempt DateTime? @map("last_verify_attempt") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([enabled])
  @@map("user_mfa")
}

model MFAAuditLog {
  id          BigInt    @id @default(autoincrement())
  userId      String    @map("user_id") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  eventType   String    @map("event_type") @db.VarChar(50) // 'enroll', 'verify', 'disable', 'backup_used', 'failed_attempt'
  eventData   Json?     @map("event_data") @db.JsonB
  ipAddress   String?   @map("ip_address") @db.Inet
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([tenantId])
  @@index([eventType])
  @@index([createdAt])
  @@map("mfa_audit_log")
}

